{
	"languages": {
		"Vue.js": {
			"language_servers": [
				"vue-language-server",
				"eslint",
				"!biome",
				"!vtsls",
				"..."
			]
		},
		"JavaScript": {
			"language_servers": [
				"typescript-language-server",
				"eslint",
				"!biome",
				"!vtsls",
				"..."
			],
			"formatter": { "language_server": { "name": "eslint" } }
		},
		"TypeScript": {
			"language_servers": [
				"typescript-language-server",
				"eslint",
				"!biome",
				"!vtsls",
				"..."
			],
			"formatter": { "language_server": { "name": "eslint" } }
		}
	},
	"code_actions_on_format": {
		"source.fixAll.eslint": true,
		"source.fixAll.biome": false,
		"source.organizeImports.biome": false
	}
}
