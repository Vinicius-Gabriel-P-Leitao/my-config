cockpit.{$DOMAIN} {
    @blocked not remote_ip 10.0.0.0/24

    handle @blocked {
        respond 403
    }

    handle {
        reverse_proxy host.docker.internal:9090 {
            transport http {
                tls_insecure_skip_verify
            }
            header_up Host {host}
            header_up X-Forwarded-Proto {scheme}
            header_up X-Forwarded-For {remote}
        }
    }
}
